<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WhisperDesktop.MainWindow"
        Title="Whisper 逐字稿"
        Width="820"
        Height="520"
        MinWidth="760"
        MinHeight="480"
        FontFamily="Segoe UI Variable Text, Segoe UI, system-ui"
        Background="#F3F3F3">

    <Window.Resources>
        <SolidColorBrush x:Key="WinTextPrimary"   Color="#1B1B1B" />
        <SolidColorBrush x:Key="WinTextSecondary" Color="#5E5E5E" />
        <SolidColorBrush x:Key="WinCard"          Color="#FFFFFF" />
        <SolidColorBrush x:Key="WinControl"       Color="#FBFBFB" />
        <SolidColorBrush x:Key="WinControlHover"  Color="#F6F6F6" />
        <SolidColorBrush x:Key="WinStroke"        Color="#DADCE0" />
        <SolidColorBrush x:Key="WinSubtleStroke"  Color="#E9EAEC" />
        <SolidColorBrush x:Key="WinAccent"        Color="#0078D4" />
        <SolidColorBrush x:Key="WinAccentHover"   Color="#106EBE" />
        <SolidColorBrush x:Key="WinAccentPressed" Color="#005A9E" />
        <SolidColorBrush x:Key="WinAccentSoft"    Color="#E5F1FB" />

        <!-- Custom button ControlTheme — overrides FluentTheme for all buttons in this window -->
        <ControlTheme x:Key="{x:Type Button}" TargetType="Button">
            <Setter Property="Background"               Value="{StaticResource WinControl}" />
            <Setter Property="Foreground"               Value="{StaticResource WinTextPrimary}" />
            <Setter Property="BorderBrush"              Value="{StaticResource WinStroke}" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="CornerRadius"             Value="4" />
            <Setter Property="MinHeight"                Value="32" />
            <Setter Property="Padding"                  Value="14,6" />
            <Setter Property="FontSize"                 Value="14" />
            <Setter Property="Cursor"                   Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Root">
                <Setter Property="Background" Value="{StaticResource WinControlHover}" />
            </Style>
            <Style Selector="^:pressed /template/ Border#Root">
                <Setter Property="Background" Value="#EEEEEE" />
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.45" />
            </Style>
            <!-- .primary class — filled accent button -->
            <Style Selector="^.primary">
                <Setter Property="Background"  Value="{StaticResource WinAccent}" />
                <Setter Property="BorderBrush" Value="{StaticResource WinAccent}" />
                <Setter Property="Foreground"  Value="White" />
            </Style>
            <Style Selector="^.primary:pointerover /template/ Border#Root">
                <Setter Property="Background" Value="{StaticResource WinAccentHover}" />
            </Style>
            <Style Selector="^.primary:pressed /template/ Border#Root">
                <Setter Property="Background" Value="{StaticResource WinAccentPressed}" />
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource WinTextPrimary}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource WinCard}" />
            <Setter Property="Foreground" Value="{StaticResource WinTextPrimary}" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight"   Value="32" />
            <Setter Property="MinWidth"    Value="124" />
            <Setter Property="FontSize"    Value="14" />
            <Setter Property="Background"  Value="{StaticResource WinControl}" />
            <Setter Property="Foreground"  Value="{StaticResource WinTextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource WinStroke}" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource WinCard}" />
            <Setter Property="Foreground" Value="{StaticResource WinTextPrimary}" />
        </Style>
    </Window.Styles>

    <Border Margin="10"
            Background="{StaticResource WinCard}"
            BorderBrush="{StaticResource WinStroke}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Drop zone ── -->
            <Border x:Name="DropZone"
                    Grid.Row="0"
                    DragDrop.AllowDrop="True"
                    Background="#FAFAFA"
                    BorderBrush="{StaticResource WinStroke}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22"
                    Cursor="Hand"
                    PointerEntered="DropZone_PointerEntered"
                    PointerExited="DropZone_PointerExited"
                    PointerReleased="DropZone_PointerReleased">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42"
                            Height="42"
                            Background="{StaticResource WinAccentSoft}"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <Viewbox Width="20" Height="24"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Canvas Width="20" Height="24">
                                <Path Fill="{StaticResource WinAccent}"
                                      Data="M 2,0 L 13,0 L 20,7 L 20,22 Q 20,24 18,24 L 2,24 Q 0,24 0,22 L 0,2 Q 0,0 2,0 Z" />
                                <Path Fill="#60FFFFFF"
                                      Data="M 13,0 L 20,7 L 13,7 Z" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="拖曳音訊或影片到這裡，或點擊選擇檔案"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="支援 mp3、wav、m4a、webm、mp4、mov、mkv，可一次加入多個檔案"
                                   Foreground="{StaticResource WinTextSecondary}"
                                   FontSize="13"
                                   Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Controls + file list ── -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <ComboBox x:Name="ModelCombo" SelectedIndex="1">
                            <ComboBoxItem Content="tiny" />
                            <ComboBoxItem Content="base" />
                            <ComboBoxItem Content="small" />
                            <ComboBoxItem Content="medium" />
                            <ComboBoxItem Content="large" />
                            <ComboBoxItem Content="large-v2" />
                            <ComboBoxItem Content="large-v3" />
                        </ComboBox>
                        <ComboBox x:Name="LanguageCombo" SelectedIndex="1" Margin="10,0,0,0">
                            <ComboBoxItem Content="自動偵測" Tag="" />
                            <ComboBoxItem Content="中文"     Tag="zh" />
                            <ComboBoxItem Content="English"  Tag="en" />
                            <ComboBoxItem Content="日本語"   Tag="ja" />
                            <ComboBoxItem Content="한국어"   Tag="ko" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="StartButton"
                                Content="開始轉錄"
                                Width="104"
                                Classes="primary"
                                Click="StartButton_Click" />
                        <Button x:Name="CancelButton"
                                Content="取消"
                                Width="74"
                                Margin="10,0,0,0"
                                IsEnabled="False"
                                Click="CancelButton_Click" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,14,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="FilesList" ItemsSource="{Binding Jobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource WinSubtleStroke}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="11"
                                        Margin="0,0,0,8"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="105" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding FilePath}"
                                                       Foreground="{StaticResource WinTextSecondary}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Status}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource WinTextSecondary}" />
                                        <Button Grid.Column="2"
                                                Content="下載 txt"
                                                Tag="{Binding}"
                                                IsEnabled="{Binding CanDownload}"
                                                Click="DownloadButton_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ── Log ── -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource WinTextSecondary}"
                           Margin="0,0,0,6" />
                <TextBox x:Name="LogText"
                         Grid.Row="1"
                         Height="74"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#FCFCFC"
                         BorderBrush="{StaticResource WinSubtleStroke}"
                         BorderThickness="1"
                         Padding="8"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </Grid>

            <!-- ── Progress + status ── -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ProgressBar x:Name="ProgressBar"
                             Minimum="0"
                             Maximum="100"
                             Height="6"
                             Foreground="{StaticResource WinAccent}" />
                <Grid Grid.Row="1" Margin="0,9,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="等待檔案"
                               Foreground="{StaticResource WinTextSecondary}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="清除完成項目"
                            MinWidth="112"
                            MinHeight="30"
                            Padding="10,4"
                            HorizontalAlignment="Right"
                            Click="ClearCompleted_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
